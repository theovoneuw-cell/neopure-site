    <!-- ====================== CONTACT ====================== -->
    <section class="contact panel panel--deep" id="contact" aria-label="Nous contacter">
      <span class="n-float n-float--c" aria-hidden="true"></span>

      <!-- Bulles d'engagement retirées ici (retour client : elles passaient
           derrière le formulaire / sous le bouton Envoyer). Conservées sur la
           section carte où elles restent dans les marges vides. -->

      <div class="container contact-inner">
        <div class="contact-form-wrap reveal">
          <h2 class="contact-title gradient-text">Contacte-nous !</h2>
          <!-- Envoi principal via Web3Forms (gratuit, sans serveur, fiable) :
               le JS lit la clé publique dans data-w3f-key et POST en AJAX vers
               api.web3forms.com → le message arrive dans neopurecom@gmail.com.
               OBTENIR LA CLÉ : https://web3forms.com → entrer neopurecom@gmail.com
               → la clé arrive dans cette boîte (le client la transfère) → la
               coller ici. La clé est publique par conception, pas un secret.
               REPLI : tant que la clé est vide, ou si Web3Forms échoue, le JS
               retente via Formsubmit.co (ancien service, parfois en panne) ;
               l'attribut action reste le repli ultime si le JS est coupé.
               (Formsubmit avait été activé par clic dans la boîte du client.) -->
          <form class="contact-form" data-w3f-key="de041b10-0e6f-4af2-9778-652bf8a60ac8" action="https://formsubmit.co/neopurecom@gmail.com" method="post" novalidate>
            <!-- Réglages Formsubmit -->
            <input type="hidden" name="_subject" value="Nouveau message depuis le site Neopure" />
            <input type="hidden" name="_template" value="table" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://neopure-studio.fr/#contact" />
            <!-- Honeypot anti-spam : un bot remplit ce champ, un humain ne le voit pas -->
            <input type="text" name="_honey" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
            <div class="field">
              <label for="f-nom">Nom <span aria-hidden="true">*</span></label>
              <input type="text" id="f-nom" name="nom" autocomplete="name" required placeholder="Ton nom" />
            </div>
            <div class="field">
              <label for="f-email">E-mail <span aria-hidden="true">*</span></label>
              <input type="email" id="f-email" name="email" autocomplete="email" required placeholder="ton@email.com" />
            </div>
            <div class="field">
              <label for="f-tel">Téléphone</label>
              <input type="tel" id="f-tel" name="telephone" autocomplete="tel" placeholder="06 ..." />
            </div>
            <div class="field field--chips">
              <label id="f-nature-label">Nature du message</label>
              <div class="chips" role="radiogroup" aria-labelledby="f-nature-label">
                <button type="button" class="chip" data-value="Réseaux sociaux"        role="radio" aria-checked="false">Réseaux sociaux</button>
                <button type="button" class="chip" data-value="Création de contenus"   role="radio" aria-checked="false">Création de contenus</button>
                <button type="button" class="chip" data-value="Stratégie digitale"     role="radio" aria-checked="false">Stratégie digitale</button>
                <button type="button" class="chip" data-value="Site web / Appli"       role="radio" aria-checked="false">Site web / Appli</button>
                <button type="button" class="chip" data-value="Photo / Vidéo"          role="radio" aria-checked="false">Photo / Vidéo</button>
                <!-- Les choix suivants sont repliés par défaut : le panneau
                     Contact fait 100 vh en frise, et ces quatre puces à elles
                     seules ajoutaient deux lignes au formulaire. Ils sont
                     dépliés par la puce « +4 » ci-dessous. -->
                <button type="button" class="chip chip--extra" data-value="Événement"      role="radio" aria-checked="false">Événement</button>
                <button type="button" class="chip chip--extra" data-value="DJ / Animation" role="radio" aria-checked="false">DJ / Animation</button>
                <button type="button" class="chip chip--extra" data-value="Team building"  role="radio" aria-checked="false">Team building</button>
                <button type="button" class="chip chip--extra" data-value="Autre"          role="radio" aria-checked="false">Autre</button>
                <!-- Placée en DERNIER dans le DOM : quand les puces repliées
                     sont masquées, elle se retrouve naturellement en bout de
                     deuxième ligne ; une fois dépliée, elle passe à la fin. -->
                <button type="button" class="chip chip--more" id="chipsMore" aria-expanded="false"></button>
              </div>
              <input type="hidden" id="f-nature" name="nature" value="" />
            </div>
            <div class="field">
              <label for="f-msg">Ton message</label>
              <textarea id="f-msg" name="message" rows="4" placeholder="Parle-nous de ton projet..."></textarea>
            </div>
            <div class="field field--consent">
              <label class="consent">
                <input type="checkbox" id="f-consent" name="consentement" value="oui" required />
                <span>J'accepte d'être recontacté·e au sujet de ma demande. <a href="#" data-legal="privacy">Politique de confidentialité</a>.</span>
              </label>
            </div>
            <p class="form-error" id="formError" role="alert" hidden></p>
            <button type="submit" class="btn btn-primary">Envoyer</button>
            <p class="form-note">On te répond sous 24 à 48h. Tes infos restent entre nous.</p>
          </form>
        </div>

