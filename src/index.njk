          <div class="collab reveal" data-delay="2" id="clients">
            <p class="collab-title eyebrow">Ils nous font confiance</p>
            <div class="collab-marquee" aria-label="Nos clients">
              <ul class="collab-track">
                <!-- Retour client : les logos mettaient longtemps à apparaître.
                     `loading="lazy"` en était la cause — en frise horizontale le
                     bandeau est hors du viewport au chargement, le navigateur ne
                     déclenchait donc les requêtes qu'au moment où on arrivait
                     dessus. Chargement immédiat pour la série réelle ; les
                     doublons décoratifs restent paresseux (mêmes URL → cache). -->
                {%- for c in clients %}
                <li class="collab-card"><img src="{{ c.src | rel }}" alt="{{ c.alt }}" decoding="async" fetchpriority="high"></li>
                {%- endfor %}
                <!-- Duplication pour boucle infinie en desktop (cachée en mobile) -->
                {%- for c in clients %}
                <li class="collab-card collab-card--dup" aria-hidden="true"><img src="{{ c.src | rel }}" alt="" loading="lazy" decoding="async"></li>
                {%- endfor %}
              </ul>
            </div>

