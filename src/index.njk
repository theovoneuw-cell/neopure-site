  <!-- ====================== PRELOADER « LOGO BUILD » (intro de marque) ====================== -->
  <!-- Sans JS, rien ne retirerait jamais l'overlay : on le neutralise. -->
  <noscript><style>.np-loader { display: none; }</style></noscript>
  <div class="np-loader" id="npLoader" role="progressbar" aria-label="Chargement du site"
       aria-valuemin="0" aria-valuemax="100" aria-valuenow="0">

    <!-- Scène sombre d'un seul tenant (retour client : plus de « cubes » /
         rectangles qui glissent). À la fin, elle s'ouvre en fondu pendant que
         le lockup zoome : on plonge littéralement dans le site par le logo. -->
    <div class="np-scene" aria-hidden="true"></div>

    <!-- Grain cinéma très subtil au-dessus de la scène -->
    <div class="np-grain" aria-hidden="true"></div>

    <!-- Méta de coins, langage éditorial d'agence -->
    <span class="np-corner np-corner--tl" aria-hidden="true">Depuis 2022</span>
    <span class="np-corner np-corner--tr" aria-hidden="true">Montpellier</span>

    <!-- Lockup de marque : le « .N » se balaie seul au centre, puis les lettres
         « eopure » sortent de derrière le signe (une seule image clippée →
         alignement parfait), enfin la signature se pose dessous. -->
    <div class="np-lockup" aria-hidden="true">
      <div class="np-brand-box">
        <img class="np-brand-img" src="assets/brand/LOGO_SF_BLANC.png" alt="" />
        <!-- Reflet lumineux masqué par la silhouette exacte du logo -->
        <span class="np-shine" aria-hidden="true"></span>
        <p class="np-tagline">Communication <b>×</b> Événementiel</p>
      </div>
    </div>

    <!-- Progression : fine ligne en bas + compteur dégradé -->
    <div class="np-progress" aria-hidden="true"><i id="npBar"></i></div>
    <div class="np-loader-count" aria-hidden="true"><span id="npLoaderNum">0</span><i>%</i></div>
  </div>

  <!-- Pilotage du preloader : compteur 0→100, puis rideau. Script NON différé
       pour verrouiller le scroll et démarrer l'animation dès le premier paint. -->
  <script>
    (function () {
      var root   = document.documentElement;
      var loader = document.getElementById("npLoader");
      if (!loader) return;
      root.classList.add("np-loading");

      var numEl = document.getElementById("npLoaderNum");
      var barEl = document.getElementById("npBar");
      var reduce = window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      var progress = 0;        // valeur affichée (0→100)
      var target   = 0;        // cible vers laquelle on tend
      var pageDone = false;    // window.load reçu ?
      var start    = Date.now();
      var MIN_MS   = 3200;     // signe → lettres → signature → respiration

      // Signature : découpe en caractères pour une révélation en cascade
      // (chaque caractère porte son délai ; le CSS anime, .is-sign déclenche).
      var tagEl = document.querySelector(".np-tagline");
      if (tagEl && !reduce) {
        var nodes = Array.prototype.slice.call(tagEl.childNodes);
        var ci = 0;
        nodes.forEach(function (n) {
          if (n.nodeType === 3) {                    // texte → un <i> par caractère
            var frag = document.createDocumentFragment();
            n.textContent.split("").forEach(function (ch) {
              if (ch === " ") { frag.appendChild(document.createTextNode(" ")); return; }
              var s = document.createElement("i");
              s.textContent = ch;
              s.style.transitionDelay = (ci++ * 18) + "ms";
              frag.appendChild(s);
            });
            tagEl.replaceChild(frag, n);
          } else {                                   // le <b>×</b> reste entier
            n.classList.add("np-tag-ch");
            n.style.transitionDelay = (ci++ * 18) + "ms";
          }
        });
      }

      // Timeline de l'intro — les transitions CSS font le reste :
      // balayage du « .N » → lettres qui sortent de derrière le signe → signature.
      // Pilotée dans tick() par le temps écoulé (même horloge que le compteur),
      // car les setTimeout dérivent quand le chargement occupe le main thread.
      function phase(elapsed) {
        if (elapsed >= 120)  loader.classList.add("is-mark");
        if (elapsed >= 1050) loader.classList.add("is-open");
        if (elapsed >= 1850) loader.classList.add("is-sign");
      }

      function render(v) {
        numEl.textContent = String(Math.round(v));
        barEl.style.transform = "scaleX(" + (v / 100) + ")";
        loader.setAttribute("aria-valuenow", String(Math.round(v)));
      }

      var finished = false;
      function finish() {
        if (finished) return;           // appelable depuis plusieurs chemins
        finished = true;
        render(100);
        loader.classList.add("is-done");
        root.classList.remove("np-loading");
        // Settle zoom : le hero se pose (1.055 → 1) pendant la cascade.
        root.classList.add("np-reveal");
        // Retire l'overlay du DOM une fois les colonnes parties
        // (dernière colonne : délai 0,38 s + 0,85 s de course).
        window.setTimeout(function () { loader.classList.add("is-gone"); }, 1350);
      }

      // Le compteur grimpe régulièrement au rythme de l'intro (jusqu'à ~94 %),
      // puis file à 100 % une fois la page prête et la durée mini écoulée —
      // il reste ainsi synchro avec la construction du logo.
      function tick() {
        var elapsed = Date.now() - start;
        phase(elapsed);
        var timed = Math.min(94, (elapsed / (MIN_MS - 300)) * 94);
        // Si la page tarde (vidéos, réseau lent) : le compteur continue de
        // grimper doucement vers 99 au lieu de rester figé à 94 — un compteur
        // immobile donne l'impression que le site a planté.
        if (elapsed >= MIN_MS) timed = Math.min(99, 94 + (elapsed - MIN_MS) / 450);
        target = pageDone && elapsed >= MIN_MS ? 100 : Math.max(timed, progress);
        progress += (target - progress) * 0.14;
        if (progress > 99.5) progress = 100;
        render(progress);

        if (progress >= 100 && pageDone && elapsed >= MIN_MS) {
          finish();
          return;
        }
        requestAnimationFrame(tick);
      }

      window.addEventListener("load", function () {
        pageDone = true;
        // Mouvement réduit : pas d'intro animée → on conclut sobrement et vite.
        if (reduce) { window.setTimeout(finish, 500); }
      });

      // Filet de sécurité global : si "load" tarde (vidéo hero lente), on conclut
      // dans TOUS les modes (sans lui, le mode "mouvement réduit" resterait bloqué).
      // 5 s max : au-delà, on révèle le site même si tout n'est pas téléchargé —
      // les vidéos finiront de se charger derrière.
      window.setTimeout(function () {
        pageDone = true;
        if (reduce) finish();
      }, 5000);

      if (reduce) { render(0); }
      else { requestAnimationFrame(tick); }
    })();
  </script>

