        <!-- Retour client : le bloc de trois phrases empilées faisait lourd. La
             troisième (« Et ce site que tu regardes ? ») est déplacée tout en
             bas de page, dans le pied de page — elle y prend la valeur d'une
             signature de fin plutôt que d'une ligne de plus dans un bloc. -->

        <div class="gallery">
          {%- for m in gallery %}
          {%- if m.type == "video" %}
          <figure class="gallery-item is-video g-vid reveal"{% if m.delay %} data-delay="{{ m.delay }}"{% endif %}>
            <video src="{{ m.src | rel }}" poster="{{ m.poster | rel }}" autoplay muted loop playsinline preload="metadata"></video>
            <span class="media-play" aria-hidden="true"><svg viewBox="0 0 24 24" fill="currentColor"><path d="M8 5.5v13a1 1 0 0 0 1.5.87l11-6.5a1 1 0 0 0 0-1.74l-11-6.5A1 1 0 0 0 8 5.5z"/></svg></span>
          </figure>
          {%- else %}
          <figure class="gallery-item{% if m.variant %} g-{{ m.variant }}{% endif %} reveal"{% if m.delay %} data-delay="{{ m.delay }}"{% endif %}><img src="{{ m.src | rel }}" alt="{{ m.alt }}" loading="lazy"></figure>
          {%- endif %}
          {%- endfor %}
        </div>

        <!-- Indice de défilement (mobile) : sans lui, on croit que la galerie
             s'arrête aux 2 premières tuiles visibles à l'écran. -->
        <p class="gallery-swipe" aria-hidden="true">Fais défiler <i>&#8594;</i></p>
      </div>
    </section>

